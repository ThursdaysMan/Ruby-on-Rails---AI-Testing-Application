<head>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
</head>

<header style="height: 5vh;">
  <div class="container-fluid">
    
    <div class="row align-items-center">
      
      <div class="col-sm-1">  
        <img src="https://upload.wikimedia.org/wikipedia/commons/8/85/Smiley.svg" style="height:20px;"></img>
      </div>
      
      <div class="col-sm-2">
        <%= link_to root_path, class: "text-decoration-none text-reset" do %>  
          <h1>
            SIRIUS 
          </h1>
        <% end %>
      </div>

      <div class="col-sm-5">
      </div>

    
      <div class="col-sm-1 nav-item">
        <%= link_to "Sign Up",
          new_user_registration_path,
          class:'nav-link' %>
      </div>

      <div class="col-sm-1 nav-item">
        <%= link_to "Sign In",
          new_user_session_path,
          class:'nav-link' %>
      </div>

      <div class="col-sm-1 nav-item">
        <%= link_to "Edit Profile",
          edit_user_registration_path,
          class:'nav-link' %>
      </div>

      <div class="col-sm-1 nav-item">
        <%= link_to "Sign Out",
          destroy_user_session_path,
          class:'nav-link' %>
      </div>

    </div>

  </div>

</header>