<head>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
</head>

<header style="height: 6vh;">
  <div class="container-fluid">
    
    <div class="row align-items-center">
      
      <div class="col-sm-1">
        <%= image_tag "Sirius-Logo.svg", alt: "Sirius App Logo", class: "navbar-brand d-flex align-items-center", height: 50 %>
      </div>
      
      <div class="col-sm-2">
        <%= link_to root_path, class: "text-decoration-none text-reset text-start" do %>  
          <h1>
            SIRIUS 
          </h1>
        <% end %>
      </div>

      <div class="col-sm-5">
      </div>

    
      <div class="col-sm-1 nav-item align-items-center">
        <%= link_to "Sign Up",
          new_user_registration_path,
          class:'nav-link' %>
      </div>

      <div class="col-sm-1 nav-item align-items-center">
        <%= link_to "Sign In",
          new_user_session_path,
          class:'nav-link' %>
      </div>

      <div class="col-sm-1 nav-item align-items-center">
        <%= link_to "Edit Profile",
          edit_user_registration_path,
          class:'nav-link' %>
      </div>

      <div class="col-sm-1 nav-item align-items-center">
        <%= link_to "Sign Out",
          destroy_user_session_path,
          class:'nav-link' %>
      </div>

    </div>

  </div>

</header>